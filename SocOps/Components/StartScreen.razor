<div class="retro-screen flex flex-col items-center justify-center min-h-full p-6">
    <div class="text-center max-w-sm w-full">

        <div class="mb-8 retro-stagger-1">
            <h1 class="font-pixel text-glow mb-4" style="font-size: 1.4rem">SOC OPS</h1>
            <p class="font-terminal text-glow-dim text-lg">// SOCIAL BINGO v1.0 //</p>
        </div>

        <div class="card-retro mb-8 text-left retro-stagger-2">
            <p class="font-terminal text-glow mb-3" style="font-size: 1.1rem">[ HOW TO PLAY ]</p>
            <hr class="retro-divider" />
            <ul class="font-terminal text-glow-dim space-y-2" style="font-size: 1.1rem">
                <li>&gt; Find people who match the prompts</li>
                <li>&gt; Tap a square when you find a match</li>
                <li>&gt; Get 5 in a row to WIN!</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="btn-retro w-full py-4 px-8 retro-stagger-3"
            style="font-size: 1.3rem">
            [ START GAME ]
        </button>

        <p class="font-terminal text-retro-dim mt-6 retro-stagger-4" style="font-size: 0.9rem">
            INSERT COIN TO CONTINUE
            <span class="blink">_</span>
        </p>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
