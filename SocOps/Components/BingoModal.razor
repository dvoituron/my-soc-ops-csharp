<div class="fixed inset-0 retro-overlay flex items-center justify-center p-4 z-50">
    <div class="card-retro max-w-xs w-full text-center retro-modal-anim">

        <p class="font-terminal text-retro-dim mb-3" style="font-size: 1rem; letter-spacing: 0.1em">
            *** WINNER ***
        </p>

        <h2 class="font-pixel text-glow-amber blink mb-4" style="font-size: 1.8rem">
            BINGO!
        </h2>

        <p class="font-terminal text-glow-dim mb-2" style="font-size: 1.1rem">
            LINE COMPLETE
        </p>
        <p class="font-terminal text-retro-dim mb-6" style="font-size: 0.95rem">
            &gt; Congratulations, player one!
        </p>

        <button
            @onclick="OnDismiss"
            class="btn-retro w-full py-3 px-6"
            style="font-size: 1.1rem">
            [ KEEP PLAYING ]
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
