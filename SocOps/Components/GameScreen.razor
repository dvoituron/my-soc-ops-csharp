@using SocOps.Models

<div class="retro-screen flex flex-col min-h-full">
    <!-- Header -->
    <header class="retro-header flex items-center justify-between p-3">
        <button
            @onclick="OnReset"
            class="btn-retro px-3 py-1"
            style="font-size: 1rem">
            &lt; BACK
        </button>
        <h1 class="font-pixel text-glow" style="font-size: 0.65rem">SOC OPS</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <p class="font-terminal text-glow-dim text-center py-2 px-4" style="font-size: 1rem">
        &gt; Tap a square when you find someone who matches it
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="retro-banner font-terminal text-center py-2" style="font-size: 1.1rem">
            *** BINGO! YOU GOT A LINE! ***
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
